# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=retail_inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Azure SQL Edge (Service Bus emulator dependency)
MSSQL_SA_PASSWORD=your_strong_sa_password_here

# JWT signing key — use a long random string (32+ characters)
JWT_KEY=your_jwt_signing_key_here

# Azure Service Bus connection string
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://servicebus;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your_key=;UseDevelopmentEmulator=true;
